# 复制为 .env 后填入真实值。
# core 独立部署版:不包含 Stripe 等商业凭据。
# 用户数据库与 cloud 部署共用同一物理 Postgres 也可以(各自只跑自己的 migrations)。

ENV=development
PORT=8080
# 镜像构建会注入这两个值；直接运行二进制时可在这里设置。生产环境不接受
# local/unknown，所有 live Core 的值必须一致。
OPENLINKER_RELEASE_ID=local
OPENLINKER_GIT_SHA=unknown

# 单实例使用进程内 signal bus。expected_replicas > 1 时必须设为 true，
# Redis 故障会让 /readyz 返回 503，但 PostgreSQL reconcile 仍继续运行。
RUNTIME_HA_MODE=false

# Dedicated Agent Runtime device listener. Leave disabled until the server
# certificate/key and the CA that enrolls Runtime Worker client certificates are
# mounted. OpenLinker Runtime never trusts forwarded certificate headers.
RUNTIME_MTLS_ENABLED=false
RUNTIME_MTLS_PORT=8443
RUNTIME_MTLS_API_URL=
RUNTIME_MTLS_CERT_FILE=
RUNTIME_MTLS_KEY_FILE=
RUNTIME_MTLS_CLIENT_CA_FILE=
RUNTIME_INVOCATION_SIGNING_KEY_ID=current
RUNTIME_INVOCATION_SIGNING_SECRET=replace-me-with-a-separate-32-byte-random-secret
# During rotation, deploy the new active pair and retain the predecessor until
# every capability issued under it has passed its Attempt deadline.
RUNTIME_INVOCATION_PREVIOUS_SIGNING_KEY_ID=
RUNTIME_INVOCATION_PREVIOUS_SIGNING_SECRET=
LOG_LEVEL=debug

DATABASE_URL=postgres://dev:dev@localhost:5432/openlinker?sslmode=disable
REDIS_URL=redis://localhost:6379/0
DB_MAX_CONNS=20
DB_MIN_CONNS=2
DB_MAX_CONN_LIFETIME_MINUTES=30
DB_MAX_CONN_IDLE_TIME_MINUTES=5
DB_HEALTH_CHECK_PERIOD_SECONDS=60

# 生成方法: openssl rand -hex 32
JWT_SECRET=replace-me-with-32-chars-random-secret
JWT_EXPIRE_HOURS=24
OAUTH_SESSION_SECRET=
# Rolling release gate: keep legacy-jwt until migration 078 and every reader
# are compatible; then switch Core and Cloud to subject-only together.
OAUTH_CODE_STORAGE_MODE=legacy-jwt

# First-admin bootstrap. These predictable values are accepted only when ENV
# is local/dev/development/test. Staging and production must replace both.
OPENLINKER_BOOTSTRAP_ADMIN_EMAIL=admin@openlinker.ai
OPENLINKER_BOOTSTRAP_ADMIN_DISPLAY_NAME=OpenLinker Admin
OPENLINKER_BOOTSTRAP_ADMIN_PASSWORD=openlinker-admin

# Google OAuth (console.cloud.google.com)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# GitHub OAuth (github.com/settings/developers)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# URL
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:8080
# 可选：OAuth provider 回调公网基址；留空则使用 API_URL。
# 如果 OAuth 入口通过前端同源 /api/v1 代理发起，本地可设为 http://localhost:3000。
OAUTH_CALLBACK_BASE_URL=
# 可选：OAuth 完成后允许回跳的前端 origin，逗号分隔；支持 https://*.example.com。
# FRONTEND_URL 始终自动允许。生产/测试前端共用同一 core 时可配置通配主域名。
OAUTH_ALLOWED_FRONTEND_ORIGINS=

# 可选：保护 POST /internal/user-tokens/introspect，也可用于 LLM 内部代理。
# 不接 Hosted/私有内部服务的自托管部署可留空（此时内省端点拒绝所有请求）。
OPENLINKER_INTERNAL_TOKEN=

# Cloud -> Core External Execution 使用独立 Ed25519 服务身份，不复用上面的
# shared token。只把 32-byte raw public key 的 base64 放到 Core；私钥只在 Cloud。
# 留空时不挂载 External Execution 内部端点。
EXTERNAL_EXECUTION_JWT_CURRENT_PUBLIC_KEY=
EXTERNAL_EXECUTION_JWT_CURRENT_KEY_ID=current
# Optional staged rotation key. Set both values or neither.
EXTERNAL_EXECUTION_JWT_NEXT_PUBLIC_KEY=
EXTERNAL_EXECUTION_JWT_NEXT_KEY_ID=
EXTERNAL_EXECUTION_JWT_ISSUER=openlinker-cloud
EXTERNAL_EXECUTION_JWT_AUDIENCE=openlinker-core.external-execution
# Migration 074 stamps legacy rows with this namespace. Keep it exactly
# openlinker-cloud until an explicit data rekey migration is deployed.
EXTERNAL_EXECUTION_CALLER_SERVICE_ID=openlinker-cloud
# Release A only: false accepts completely legacy tokens. Set true after every
# caller has sent v1 bindings for at least the maximum JWT TTL plus leeway.
EXTERNAL_EXECUTION_REQUEST_BINDING_REQUIRED=false

# 可选:托管/cloud 部署可提供内部 LLM completion 端点。
# 开源 core 独立使用可留空,任务推荐会走规则 fallback,benchmark 会显示 LLM 不可用。
LLM_COMPLETE_URL=

# 业务参数
RUN_TIMEOUT_SECONDS=60
RUNTIME_ENDPOINT_RUN_WORKER_ENABLED=true
RUNTIME_ENDPOINT_RUN_WORKER_INTERVAL_SECONDS=30
# 0 表示使用 max(RUN_TIMEOUT_SECONDS+30s, 180s)
RUNTIME_ENDPOINT_RUN_TIMEOUT_SECONDS=0
RUNTIME_ENDPOINT_RUN_WORKER_BATCH_SIZE=50

# 本地真实 Agent 调试时可设 true；仅接受 localhost/loopback HTTP endpoint。
ALLOW_LOCAL_HTTP_ENDPOINTS=false
