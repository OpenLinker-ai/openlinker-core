# 复制为 .env 后填入真实值。
# core 独立部署版:不包含 Stripe / Anthropic 等商业凭据。
# 用户数据库与 cloud 部署共用同一物理 Postgres 也可以(各自只跑自己的 migrations)。

ENV=development
PORT=8080
LOG_LEVEL=debug

DATABASE_URL=postgres://dev:dev@localhost:5432/openlinker?sslmode=disable
REDIS_URL=redis://localhost:6379/0
DB_MAX_CONNS=20
DB_MIN_CONNS=2
DB_MAX_CONN_LIFETIME_MINUTES=30
DB_MAX_CONN_IDLE_TIME_MINUTES=5
DB_HEALTH_CHECK_PERIOD_SECONDS=60

# 生成方法: openssl rand -hex 32
JWT_SECRET=replace-me-with-32-chars-random-secret
JWT_EXPIRE_HOURS=24

# Google OAuth (console.cloud.google.com)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# GitHub OAuth (github.com/settings/developers)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# URL
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:8080

# 可选:平台版部署时,core 通过 cloud 内部端点验证 ol_live/sk_live API key。
# 开源 core 独立使用可留空,则 API key 鉴权不可用,JWT 鉴权不受影响。
API_KEY_VERIFY_URL=

# 业务参数
PLATFORM_FEE_RATE=0.25
RUN_BILLING_MODE=free
RUN_TIMEOUT_SECONDS=60

# 本地真实 Agent 调试时可设 true；仅接受 localhost/loopback HTTP endpoint。
ALLOW_LOCAL_HTTP_ENDPOINTS=false
