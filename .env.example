# 复制为 .env 后填入真实值。
# core 独立部署版:不包含 Stripe 等商业凭据。
# 用户数据库与 cloud 部署共用同一物理 Postgres 也可以(各自只跑自己的 migrations)。

ENV=development
PORT=8080
LOG_LEVEL=debug

DATABASE_URL=postgres://dev:dev@localhost:5432/openlinker?sslmode=disable
REDIS_URL=redis://localhost:6379/0
DB_MAX_CONNS=20
DB_MIN_CONNS=2
DB_MAX_CONN_LIFETIME_MINUTES=30
DB_MAX_CONN_IDLE_TIME_MINUTES=5
DB_HEALTH_CHECK_PERIOD_SECONDS=60

# 生成方法: openssl rand -hex 32
JWT_SECRET=replace-me-with-32-chars-random-secret
JWT_EXPIRE_HOURS=24
OAUTH_SESSION_SECRET=

# First-admin bootstrap. If no admin exists, Core creates this user at startup.
OPENLINKER_BOOTSTRAP_ADMIN_EMAIL=admin@openlinker.ai
OPENLINKER_BOOTSTRAP_ADMIN_DISPLAY_NAME=OpenLinker Admin
# Default password when unset: openlinker-admin
# OPENLINKER_BOOTSTRAP_ADMIN_PASSWORD=

# Google OAuth (console.cloud.google.com)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# GitHub OAuth (github.com/settings/developers)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# URL
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:8080
# 可选：OAuth provider 回调公网基址；留空则使用 API_URL。
# 如果 OAuth 入口通过前端同源 /api/v1 代理发起，本地可设为 http://localhost:3000。
OAUTH_CALLBACK_BASE_URL=
# 可选：OAuth 完成后允许回跳的前端 origin，逗号分隔；支持 https://*.example.com。
# FRONTEND_URL 始终自动允许。生产/测试前端共用同一 core 时可配置通配主域名。
OAUTH_ALLOWED_FRONTEND_ORIGINS=

# 可选：在 Core 本地签发与验证 User Token 落地前，可接入外部验证端点。
# 留空时当前版本仅支持 JWT；该配置不是 User Token 的长期归属边界。
USER_TOKEN_VERIFY_URL=
OPENLINKER_INTERNAL_TOKEN=

# 可选:托管/cloud 部署可提供内部 LLM completion 端点。
# 开源 core 独立使用可留空,任务推荐会走规则 fallback,benchmark 会显示 LLM 不可用。
LLM_COMPLETE_URL=

# 业务参数
RUN_TIMEOUT_SECONDS=60
RUNTIME_ENDPOINT_RUN_WORKER_ENABLED=true
RUNTIME_ENDPOINT_RUN_WORKER_INTERVAL_SECONDS=30
# 0 表示使用 max(RUN_TIMEOUT_SECONDS+30s, 180s)
RUNTIME_ENDPOINT_RUN_TIMEOUT_SECONDS=0
RUNTIME_ENDPOINT_RUN_WORKER_BATCH_SIZE=50

# 本地真实 Agent 调试时可设 true；仅接受 localhost/loopback HTTP endpoint。
ALLOW_LOCAL_HTTP_ENDPOINTS=false
